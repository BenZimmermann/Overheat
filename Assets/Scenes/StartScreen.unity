  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Thanks for Playing\r\n\"Overheat\"\r\n\r\nA Game By\nPaper Crane Studio\n\r\nGame
    Director/ Producers:\r\nBen Zimmermann\r\n\r\nGame Designer:\r\nBen Zimmermann\r\n\r\nProgrammer:\r\nBen
    Zimmermann\r\n\r\n3D Artist:\r\nBen Zimmermann\r\nSketchfab\r\n\r\n2D Artist:\r\nBen
    Zimmermann\r\n\r\nLevel Designer:\r\nBen Zimmermann\r\n\r\n3D Animations:\r\nBen
    Zimmermann\r\nMixamo\r\n\r\nSpecial VFX:\r\nBen Zimmermann\r\nGabriel Aguiar\r\n\r\nIdea:\r\nPinterest\r\nBen
    Zimmermann\r\n\r\nMusic/Sounds:\r\n\r\nSoftware Used:\r\nUnity 6.3 LTS\r\nBlender
    5\r\nBlockbench\r\nLibreSprite\r\n\r\nThird-Party Plugins:\r\nPro builder\r\n\r\nSpecial
    Thanks:\r\nOliver \nNico\nEmma\r\nYouTube\nMy Family\r\nMy cats\nMy Bunny\r\n\r\nMade
    as a lerning project\r\nat SRH Heidelberg\r\n2026\r\n\r\n\n\n\n\n\n\nSome Random
    Stats:\r\n50+ objects\r\n3 different enemies\r\n6 different items\r\n6 different
    weapons\r\n12 different Upgrades\r\n300+ hours of development\n in 2 months\r\n~5000
    Lines of Code \n\n<3"
